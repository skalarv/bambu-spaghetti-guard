[run]
branch = True
# Coverage is measured on the shipped package only. verification/ is test
# infrastructure — counting it inflates the headline number with
# mock-testing-the-mock.
source =
    src/spaghetti_guard

[report]
show_missing = True
skip_covered = False
fail_under = 90
exclude_lines =
    pragma: no cover
    if __name__ == "__main__":
    if TYPE_CHECKING:
    raise NotImplementedError
    \.\.\.

[paths]
source =
    src/spaghetti_guard
